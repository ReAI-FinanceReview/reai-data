# Application env
APP_ENV=dev/prod

# Parquet Storage (NAS or local)
# Development: ./data/parquet
# Production: /mnt/nas/reai-data
PARQUET_BASE_PATH=./data/parquet
ENABLE_PARQUET_WRITE=true

# Database (prefer DATABASE_URL; fallback to DB_* parts)
DB_TYPE=postgresql
DB_NAME=dbname
DB_URL=postgresql+psycopg2://user:password@host:port/dbname
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password

# Test database (프로덕션 DB와 반드시 분리된 testdb 데이터베이스를 지정할 것)
# 서버 개발 (VS Code Remote SSH): postgresql://vector_mgr:password@reai.kro.kr:55000/testdb
# 로컬 개발 (docker-compose): docker-compose -f docker-compose.test.yml up -d 후 아래 기본값 사용
# TEST_DATABASE_URL=postgresql://testuser:testpass@localhost:5433/testdb

# OpenAI
OPENAI_API_KEY=YOUR_API_KEY_HERE

# Java (for konlpy/Okt if needed)
# JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64