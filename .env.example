# 환경 및 로그 설정
ENVIRONMENT=development
LOG_LEVEL=INFO

# 데이터베이스 설정
DATABASE_URL=postgresql+psycopg2://user:password@host:port/dbname

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# MinIO 설정 (http(s):// prefix 없이 host:port 형식으로 작성)
MINIO_ENDPOINT=host:9000
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
MINIO_BUCKET=reai-data
MINIO_USE_SSL=False

# Parquet 쓰기 활성화 (false로 설정 시 MinIO 업로드 및 ingestion_batch 등록 건너뜀)
ENABLE_PARQUET_WRITE=true

# Test database (프로덕션 DB와 반드시 분리된 testdb 데이터베이스를 지정할 것)
# TEST_DATABASE_URL=postgresql://testuser:testpass@localhost:5433/testdb

# Java (for konlpy/Okt if needed)
# JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
